PORT=3000
HOST=127.0.0.1
AUTH_TOKEN=replace-with-a-long-random-token
AUTH_MIN_TOKEN_LENGTH=24
AUTH_SESSION_COOKIE_NAME=codex_remote_session
AUTH_SESSION_TTL_MS=43200000
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX=10
API_RATE_LIMIT_WINDOW_MS=600000
API_RATE_LIMIT_MAX=2400
CODEX_BIN=codex
CODEX_COMMAND=codex --sandbox workspace-write -a on-request --no-alt-screen
ENABLE_CLOUDFLARE_TUNNEL=true
ENABLE_TAILSCALE_PRIVATE=false
CLOUDFLARE_TUNNEL_MODE=quick
CLOUDFLARE_TUNNEL_NAME=codex-remote
CLOUDFLARE_TUNNEL_HOSTNAME=
CAPTURE_LINES=4000
RESPONSE_TIMEOUT_MS=120000
POLL_INTERVAL_MS=1200
IDLE_POLLS_BEFORE_FALLBACK=3
MAX_PROMPT_CHARS=12000
APP_SERVER_TIMEOUT_MS=20000
THREAD_PAGE_SIZE=100
THREAD_SYNC_TIMEOUT_MS=12000
THREAD_SYNC_POLL_MS=600
